---
import Hero from "@/components/Hero.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { productCategories } from "@/data/products";
---

<BaseLayout title="製品一覧" description="INBESが企画・販売する製品をご紹介しています。" siteMode="products">
  <Hero eyebrow="Products" title="製品一覧" lead="INBESが企画・販売する製品をご紹介しています。詳しい仕様や販売情報は、各製品ページで確認できます。" />

  <section id="support" class="container-page scroll-mt-24 pb-8">
    <div class="grid gap-5 rounded-lg border border-line bg-white p-6 md:grid-cols-[1fr_auto] md:items-center md:p-8">
      <div>
        <p class="eyebrow">Support</p>
        <h2 class="mb-3 text-2xl font-extrabold md:text-3xl">サポート</h2>
        <p class="text-sub">ご利用中の製品に関する確認事項は、サポートフォームまたはお電話からお問い合わせください。</p>
        <p class="mt-3 text-sm font-bold text-sub">TEL 042-316-9823 / 平日 9:00〜18:00</p>
      </div>
      <a class="button button-primary" href="/contact/support/">サポートへ問い合わせる</a>
    </div>
  </section>

  <section id="lineup" class="section container-page scroll-mt-24">
    <div class="section-heading">
      <p class="eyebrow">Lineup</p>
      <h2>製品一覧</h2>
      <p>販売中の製品はカテゴリごとに整理して掲載します。詳細な仕様や販売情報は、各製品ページで確認できます。</p>
    </div>
    <div class="grid gap-14 md:gap-20">
      {productCategories.map((category) => (
        <section>
          <div class="mb-7 border-t border-line pt-5">
            <p class="eyebrow">{category.eyebrow}</p>
            <h2 class="text-2xl font-extrabold md:text-4xl">{category.title}</h2>
          </div>
          <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
            {category.products.map((product) => (
              <article class="flex h-full flex-col rounded-lg border border-line bg-white p-6">
                <div class="placeholder mb-5 aspect-[4/3]">{product.title}</div>
                <p class="mb-2 text-xs font-extrabold text-green">{product.tag}</p>
                <h3 class="mb-3 text-xl font-extrabold">{product.title}</h3>
                <p class="mb-6 text-sm text-sub">{product.description}</p>
                <a
                  class="mt-auto w-fit font-extrabold text-blue underline underline-offset-4 after:ml-1 after:content-['↗']"
                  href={product.url}
                  target="_blank"
                  rel="noopener"
                >
                  {product.linkLabel}
                </a>
              </article>
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>
