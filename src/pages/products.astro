---
import Hero from "@/components/Hero.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { productCategories } from "@/data/products";
---

<BaseLayout title="自社製品" description="INBESが企画・販売する製品をご紹介しています。" siteMode="products">
  <Hero eyebrow="Products" title="自社製品" lead="INBESが企画・販売する製品をご紹介しています。製品一覧やサポートに関するお問い合わせはこちらから確認できます。" />

  <section id="support" class="container-page scroll-mt-24 pb-8">
    <div class="grid gap-5 rounded-lg border border-line bg-white p-6 md:grid-cols-[1fr_auto] md:items-center md:p-8">
      <div>
        <p class="eyebrow">Support</p>
        <h2 class="mb-3 text-2xl font-extrabold md:text-3xl">サポート</h2>
        <p class="text-sub">ご利用中の製品に関する確認事項は、サポートフォームまたはお電話からお問い合わせください。</p>
      </div>
      <a class="button button-primary" href="/contact/support/">サポートへ問い合わせる</a>
    </div>
  </section>

  <section id="lineup" class="section container-page scroll-mt-24">
    <div class="section-heading">
      <p class="eyebrow">Lineup</p>
      <h2>製品一覧</h2>
      <p>販売中の製品はカテゴリごとに整理して掲載します。詳細な仕様や販売情報は、各製品ページで確認できます。</p>
    </div>
    <div class="grid gap-5 md:grid-cols-3">
      {productCategories.map((category) => (
        <article class="rounded-lg border border-line bg-white p-6">
          <div class="placeholder mb-5 aspect-[4/3]">{category.title}</div>
          <h2 class="mb-3 text-xl font-extrabold">{category.title}</h2>
          <p class="mb-5 text-sm text-sub">{category.description}</p>
          <div class="flex flex-wrap gap-2">
            {category.items.map((item) => <span class="rounded-full border border-line px-3 py-1 text-xs font-bold text-sub">{item}</span>)}
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
