---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="INBES株式会社" description="INBESは、自社製品の企画・販売と、日本で売るための商品化支援を行う会社です。" entrance>
  <section class="relative min-h-screen overflow-hidden">
    <div class="absolute left-1/2 top-6 z-10 -translate-x-1/2 text-center md:top-10">
      <p class="text-2xl font-extrabold tracking-normal">INBES</p>
      <p class="mt-1 text-xs font-bold uppercase tracking-[0.12em] text-sub">Products / Product Development</p>
    </div>

    <div class="grid min-h-screen md:grid-cols-2">
      <a
        href="/products/"
        class="group relative flex min-h-[50vh] items-end border-b border-line bg-white p-7 transition md:min-h-screen md:border-b-0 md:border-r md:p-12 lg:p-16"
        aria-label="自社製品ページへ"
      >
        <div class="absolute inset-x-7 top-24 h-[34vh] min-h-[220px] overflow-hidden rounded-lg md:inset-x-12 md:top-28 lg:inset-x-16">
          <div class="placeholder h-full w-full transition duration-500 group-hover:scale-[1.03]">Product Image</div>
        </div>
        <div class="relative z-10 max-w-xl pt-[42vh] md:pt-0">
          <p class="eyebrow">For Users</p>
          <h1 class="mb-5 text-4xl font-extrabold leading-tight md:text-6xl">自社製品</h1>
          <p class="mb-8 text-sub">INBESが企画・販売する製品情報、修理、サポートをお探しの方へ。</p>
          <span class="font-extrabold text-blue underline underline-offset-4">製品情報を見る</span>
        </div>
      </a>

      <a
        href="/services/"
        class="group relative flex min-h-[50vh] items-end bg-soft p-7 transition hover:bg-paper md:min-h-screen md:p-12 lg:p-16"
        aria-label="商品化支援ページへ"
      >
        <div class="absolute inset-x-7 top-24 h-[34vh] min-h-[220px] overflow-hidden rounded-lg md:inset-x-12 md:top-28 lg:inset-x-16">
          <div class="placeholder h-full w-full transition duration-500 group-hover:scale-[1.03]">Development Image</div>
        </div>
        <div class="relative z-10 max-w-xl pt-[42vh] md:pt-0">
          <p class="eyebrow">For Business</p>
          <h2 class="mb-5 text-4xl font-extrabold leading-tight md:text-6xl">商品化支援</h2>
          <p class="mb-8 text-sub">OEM・ODM、ローカライズ開発、販売準備まで。日本で売るための商品づくりを支援します。</p>
          <span class="font-extrabold text-blue underline underline-offset-4">商品化支援を見る</span>
        </div>
      </a>
    </div>

    <nav class="absolute bottom-5 left-1/2 z-10 flex -translate-x-1/2 gap-5 rounded-full border border-line bg-paper/80 px-5 py-2 text-xs font-bold text-sub backdrop-blur" aria-label="補助ナビゲーション">
      <a href="/company/" class="hover:text-ink">会社概要</a>
      <a href="/contact/" class="hover:text-ink">お問い合わせ</a>
    </nav>
  </section>
</BaseLayout>
