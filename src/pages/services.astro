---
import Hero from "@/components/Hero.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { fields } from "@/data/services";
import { works } from "@/data/works";
---

<BaseLayout title="商品化支援" description="海外製品のローカライズから、仕様整理、量産、輸入、パッケージ制作まで。日本で販売するための商品化を、一緒に進めます。">
  <Hero
    eyebrow="Product Development Support"
    title="日本で売るための、商品づくりを共に。"
    lead="海外製品のローカライズから、仕様整理、量産、輸入、パッケージ制作まで。日本で販売するための商品化を、一緒に進めます。"
  />

  <section class="section container-page">
    <div class="section-heading">
      <p class="eyebrow">Issue</p>
      <h2>商品化で、よくあること。</h2>
      <p>商品化の進め方は、一社一社異なります。INBESは、日本で販売するために必要な工程を、状況に合わせて一緒に整理します。</p>
    </div>
    <div class="grid gap-5 md:grid-cols-3">
      {[
        ["01", "エレクトロニクス商品を扱いたい", "認証や仕様の検討など、新規参入に必要な技術面・実務面をサポートします。"],
        ["02", "商品化を前に進めたい", "営業や企画だけでは不足しがちな技術的な検討や仕様整理を、一緒に進めます。"],
        ["03", "商品化をまとめて任せたい", "商品選定から量産、輸入、パッケージや取扱説明書まで、一つの窓口で対応します。"]
      ].map(([number, title, text]) => (
        <article class="border-t border-line bg-white p-6">
          <span class="mb-5 block text-sm font-extrabold text-green">{number}</span>
          <div class="placeholder mb-6 aspect-[4/3]">Image</div>
          <h3 class="mb-3 text-xl font-extrabold">{title}</h3>
          <p class="text-sm text-sub">{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section container-page">
    <div class="section-heading">
      <p class="eyebrow">Fields</p>
      <h2>主な取扱分野</h2>
      <p>バッテリー・電源関連をはじめ、生活家電やカー用品、スマートフォン・PC周辺機器など、エレクトロニクス製品を中心に商品化を支援しています。</p>
    </div>
    <div class="grid gap-5 md:grid-cols-3">
      {fields.map(([title, text]) => (
        <article class="rounded-lg border border-line bg-white p-6">
          <div class="placeholder mb-5 aspect-[4/3]">{title}</div>
          <h3 class="mb-3 text-xl font-extrabold">{title}</h3>
          <p class="text-sm text-sub">{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section bg-white">
    <div class="container-page">
      <div class="section-heading">
        <p class="eyebrow">Development Approach</p>
        <h2>商品化の考え方</h2>
        <p>ゼロから作ることだけが、商品開発ではありません。INBESでは、海外で実績のある製品や新たに開発された製品を活用し、日本市場に合わせた商品化をご提案しています。</p>
      </div>
      <div class="grid gap-6 lg:grid-cols-[1.35fr_0.65fr]">
        <article class="rounded-lg border border-line bg-paper p-7 md:p-10">
          <p class="eyebrow">Main Approach</p>
          <h3 class="mb-4 text-2xl font-extrabold md:text-4xl">ローカライズ開発</h3>
          <p class="mb-8 text-sub">海外で実績のある製品や、新たに開発された製品を、日本市場や販売先に合わせて商品化する開発手法です。</p>
          <div class="grid gap-4 md:grid-cols-4">
            {["製品・技術を選定", "日本市場へ最適化", "販売条件を整える", "商品として届ける"].map((step, index) => (
              <div class="border-t border-line pt-4">
                <span class="mb-3 block text-sm font-extrabold text-green">{String(index + 1).padStart(2, "0")}</span>
                <p class="font-extrabold">{step}</p>
              </div>
            ))}
          </div>
        </article>
        <article class="rounded-lg border border-line p-7 md:p-10">
          <h3 class="mb-4 text-2xl font-extrabold">オリジナル開発</h3>
          <p class="text-sub">ローカライズ開発では対応できない場合の選択肢です。必要な機能や用途に合わせて、新規開発にも対応しています。</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container-page grid gap-8 md:grid-cols-[1fr_auto] md:items-center">
      <div>
        <p class="eyebrow">Process</p>
        <h2 class="mb-5 text-3xl font-extrabold leading-tight md:text-5xl">相談から販売準備まで。</h2>
        <p class="max-w-2xl text-sub">作りたい商品が決まっている場合も、探すところから始めたい場合も、状況に合わせて商品化を進めます。</p>
      </div>
      <a class="button button-secondary" href="/process/">進め方を見る</a>
    </div>
  </section>

  <section class="section container-page">
    <div class="grid gap-10 md:grid-cols-[0.8fr_1.2fr] md:items-center">
      <div>
        <p class="eyebrow">Works</p>
        <h2 class="mb-5 text-3xl font-extrabold leading-tight md:text-5xl">どんな商品を、どこまで支援したか。</h2>
        <p class="mb-8 text-sub">開発実績では、商品化を支援した製品と関与範囲を一覧で確認できます。</p>
        <a class="button button-secondary" href="/works/">開発実績を見る</a>
      </div>
      <div class="grid grid-cols-2 gap-4 md:grid-cols-3">
        {works.slice(0, 6).map((work) => (
          <div class="placeholder aspect-[4/3] p-4 text-center">{work.title}</div>
        ))}
      </div>
    </div>
  </section>

  <section class="mx-5 mb-16 rounded-lg bg-ink px-6 py-14 text-white md:mx-11 md:px-12 md:py-20">
    <h2 class="mb-8 text-3xl font-extrabold md:text-5xl">商品化をご検討中の方へ</h2>
    <div class="flex flex-col gap-3 sm:flex-row">
      <a class="button border-white bg-white text-ink" href="/contact/">商品化について相談する</a>
      <a class="button border-white text-white" href="/works/">実績を見る</a>
    </div>
  </section>
</BaseLayout>
