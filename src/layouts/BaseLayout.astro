---
import "../styles/global.css";
import { businessNavigation, footerNavigation, modeSwitch, productNavigation } from "@/data/navigation";
import { withBase } from "@/utils/paths";

type Props = {
  title?: string;
  description?: string;
  entrance?: boolean;
  siteMode?: "business" | "products";
};

const {
  title = "INBES株式会社",
  description = "INBESは、日本で売るための商品づくりを支える会社です。",
  entrance = false,
  siteMode = "business"
} = Astro.props;

const pageTitle = title === "INBES株式会社" ? title : `${title} | INBES株式会社`;
const headerNavigation = siteMode === "products" ? productNavigation : businessNavigation;
const switchLink = siteMode === "products" ? modeSwitch.products : modeSwitch.business;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
  </head>
  <body>
    {
      !entrance && (
        <header class="sticky top-0 z-20 border-b border-line bg-paper/95 backdrop-blur">
          <div class="px-5 md:px-11">
            <div class="flex min-h-16 items-center justify-between gap-5 md:min-h-[72px]">
              <div class="flex min-w-0 items-center gap-3 md:gap-4">
              <a href={withBase("/")} class="text-[22px] font-extrabold tracking-normal">INBES</a>
              <a href={withBase(switchLink.href)} class="rounded-full border border-line bg-white px-3 py-1.5 text-[11px] font-bold text-blue transition hover:border-blue md:text-xs">
                {switchLink.label}
              </a>
            </div>
            <nav class="hidden items-center gap-6 text-sm text-sub md:flex" aria-label="グローバルナビゲーション">
              {headerNavigation.map((item) => (
                <a
                  href={withBase(item.href)}
                  class:list={[
                    "transition hover:text-ink",
                    item.emphasis && "rounded-full bg-ink px-4 py-2 font-bold text-white hover:text-white"
                  ]}
                >
                  {item.label}
                </a>
              ))}
            </nav>
            </div>
            <nav class="flex gap-4 overflow-x-auto border-t border-line/70 py-3 text-xs text-sub md:hidden" aria-label="モバイルナビゲーション">
              {headerNavigation.map((item) => (
                <a
                  href={withBase(item.href)}
                  class:list={[
                    "shrink-0 transition hover:text-ink",
                    item.emphasis && "rounded-full bg-ink px-3 py-1.5 font-bold text-white hover:text-white"
                  ]}
                >
                  {item.label}
                </a>
              ))}
            </nav>
          </div>
        </header>
      )
    }

    <main>
      <slot />
    </main>

    {
      !entrance && (
        <footer class="border-t border-line px-5 py-10 md:px-11">
          <div class="grid gap-8 md:grid-cols-[1fr_auto] md:items-start">
            <div>
              <a href={withBase("/")} class="mb-3 inline-block text-xl font-extrabold">INBES</a>
              <p class="max-w-xl text-sm text-sub">株式会社INBES 〒206-0012 東京都多摩市貝取1510-1 永山JOYビル5F</p>
            </div>
            <nav class="flex flex-wrap gap-x-5 gap-y-2 text-sm text-sub md:max-w-md md:justify-end" aria-label="フッターナビゲーション">
              {footerNavigation.map((item) => <a href={withBase(item.href)} class="hover:text-ink">{item.label}</a>)}
            </nav>
          </div>
        </footer>
      )
    }
  </body>
</html>
